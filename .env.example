# База данных
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/workspot

# PostgreSQL (используется сервисом db в docker-compose)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=workspot

# JWT
SECRET_KEY=your-secret-key-min-32-chars-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Администратор (создаётся при запуске seed.py)
ADMIN_EMAIL=admin@workspot.ru
ADMIN_PASSWORD=adminpass123

# Яндекс Карты JS API v2.1
# Получить ключ: https://developer.tech.yandex.ru/
# Выбрать: "JavaScript API и HTTP Геокодер"
# Если не задан — карта заменяется заглушкой, остальное работает
YANDEX_MAPS_API_KEY=your-api-key
